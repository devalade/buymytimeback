{
  "env": {
    "browser": true,
    "es2022": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^[A-Z_]+$" }],
    "no-console": "warn",
    "eqeqeq": ["error", "always", { "null": "ignore" }],
    "curly": ["error", "all"]
  }
}
